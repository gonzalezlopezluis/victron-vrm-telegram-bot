# ========================================
# TELEGRAM BOT CONFIGURATION
# ========================================

# Token del bot de Telegram (obligatorio)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# ADMINISTRADORES (tienen permisos especiales)
# Formato: IDs separados por comas, sin espacios
TELEGRAM_ADMIN_IDS=123456789

# USUARIOS NORMALES (solo comandos básicos)
# Formato: IDs separados por comas, sin espacios
TELEGRAM_ALLOWED_IDS=987654321,555555555

# ========================================
# VRM API CONFIGURATION
# ========================================

# Token de la API de Victron VRM (obligatorio)
VRM_TOKEN=tu_token_vrm

# User ID de Victron VRM (obligatorio)
VRM_USER_ID=tu_user_id_vrm

# ========================================
# BOT CONFIGURATION
# ========================================

# Expresión cron para la comprobación diaria (formato: "minuto hora día mes día_semana")
# Ejemplo: "0 8 * * *" = todos los días a las 08:00
CRON_TIME="0 8 * * *"

# Zona horaria (lista completa: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE="Atlantic/Canary"

# Minutos sin conexión para considerar offline (número entero)
OFFLINE_THRESHOLD_MINUTES="60"

# Puerto para el servidor health check (Render asigna automáticamente)
PORT=3000